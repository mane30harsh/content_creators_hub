# ---------------------------------------------------
# Content Creators Hub — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit your actual .env file.
# ---------------------------------------------------

# --- Database (PostgreSQL) ---
# Local example: postgresql://postgres:postgres@localhost:5432/content_creators_hub
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-strong-random-secret"

# Base URL of the app (used by Auth.js for callbacks)
NEXTAUTH_URL="http://localhost:3000"

# --- OAuth Providers (optional, add as needed) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- App Config ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Content Creators Hub"
